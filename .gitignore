# This repo is YAML + Markdown only — nothing secret should ever land here.
# Guard against stray HA artifacts if the repo is ever cloned in-place under /config.
secrets.yaml
.storage/
home-assistant_v2.db*
*.db-wal
*.db-shm
home-assistant.log*
.HA_VERSION
__pycache__/
*.pyc

# Local history exports for Task A are kept OUT of version control — their seed
# results are already baked into the helper defaults and recorded in ENTITIES.md.
docs/analysis/*.csv

# Screenshots / images: this repo is text-only. Keep dashboard screenshots
# (which can leak entity IDs, network hints, or other local detail) out of git.
*.png
*.jpg
*.jpeg
*.webp
*.gif
